# ─── AI ────────────────────────────────────────────────────────────────────────
# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── GitHub OAuth ───────────────────────────────────────────────────────────────
# Create a GitHub OAuth App at https://github.com/settings/developers
# Set the callback URL to: https://<your-domain>/api/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Full URL of your deployed app (used to build the OAuth callback URL)
APP_URL=https://your-app.up.railway.app
# Optional: override the full callback URL explicitly
# GITHUB_CALLBACK_URL=https://your-app.up.railway.app/api/callback

# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string — NeonDB recommended: https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Session ───────────────────────────────────────────────────────────────────
# Random secret for signing session cookies — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ─── Document Encryption ───────────────────────────────────────────────────────
# Key for AES-256-GCM document encryption — must be at least 32 characters
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DOCUMENT_ENCRYPTION_KEY=

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Stripe secret key — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Stripe webhook signing secret — from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
